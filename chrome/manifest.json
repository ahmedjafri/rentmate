{
  "manifest_version": 3,
  "name": "TenantCloud Rent Agent",
  "version": "1.0",
  "description": "Integrates a rent management agent's suggestions into the TenantCloud maintenance chat.",
  "icons": {
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "https://*.tenantcloud.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://*.tenantcloud.com/*"],
      "js": ["suggestion.js", "content.js"]
    }
  ]
}