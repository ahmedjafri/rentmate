# Required: Your AI model API key
LLM_API_KEY=sk-...

# Optional (defaults shown)
LLM_MODEL=openai/gpt-4o-mini
LLM_BASE_URL=             # e.g. http://localhost:11434 for Ollama

# Auth
JWT_SECRET=change-me-in-production

# Database + storage
RENTMATE_DB_URI=postgresql+psycopg2://postgres:postgres@127.0.0.1:5432/rentmate
RENTMATE_DATA_DIR=./data
RENTMATE_DOCS_DIR=./data/documents

# Deployment topology
RENTMATE_DEPLOYMENT_MODE=single-machine   # single-machine | distributed
RENTMATE_DOC_GEN_BACKEND=                 # optional override: local | grpc
RENTMATE_DOC_GEN_GRPC_TARGET=127.0.0.1:50061
RENTMATE_DOC_GEN_GRPC_BIND=0.0.0.0:50061
RENTMATE_DOC_GEN_GRPC_INSECURE=true
RENTMATE_DOC_GEN_RENDER_TIMEOUT_MS=30000

# Optional: Quo (OpenPhone) SMS integration
QUO_API_KEY=
PHONE_WHITELIST=          # comma-separated list of tenant phone numbers to auto-reply to

# Optional: OpenClaw agent gateway
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_GATEWAY_TOKEN=rentmate-dev-token

TAVILY_KEY=tvly-...