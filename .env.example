# Required: Your AI model API key
LLM_API_KEY=sk-...

# Optional (defaults shown)
LLM_MODEL=openai/gpt-4o-mini
LLM_BASE_URL=             # e.g. http://localhost:11434 for Ollama

# Auth
RENTMATE_PASSWORD=rentmate
JWT_SECRET=change-me-in-production

# Storage paths
RENTMATE_DB_PATH=./data/rentmate.db
RENTMATE_DOCS_DIR=./data/documents
RENTMATE_CHROMA_DIR=./data/chroma

# Optional: Dialpad SMS integration
DIALPAD_API_KEY=
PHONE_WHITELIST=          # comma-separated list of tenant phone numbers to auto-reply to

# Optional: admin info for AI agent context
RENTMATE_ADMIN_EMAIL=admin@localhost
RENTMATE_ACCOUNT_NAME=My Property Management

# Optional: OpenClaw agent gateway
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_GATEWAY_TOKEN=rentmate-dev-token
